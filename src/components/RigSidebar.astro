---
interface Spec { k: string; v: string }
interface Buy { name: string; price: string }
interface Rig {
  name: string;
  photoLabel: string;
  ratingValue: number;
  ratingText: string;
  ratingLabel: string;
  verdict: string;
  specs: Spec[];
  buy: Buy[];
  pros: string[];
  cons: string[];
}

interface Props {
  rig: Rig;
}

const { rig } = Astro.props;

function starType(v: number, i: number): 'full' | 'half' | 'empty' {
  if (v >= i) return 'full';
  if (v >= i - 0.5) return 'half';
  return 'empty';
}
const stars = [1, 2, 3, 4, 5].map((i) => starType(rig.ratingValue, i));
---

<aside class="rig-sidebar">
  <div class="card">
    <div class="photo photo-placeholder">{rig.photoLabel}</div>
    <div class="body">
      <div class="mono label accent">The rig</div>
      <div class="serif name">{rig.name}</div>

      <div class="rating">
        <div class="stars">
          {stars.map((t) => <span class={`star star-${t}`}></span>)}
        </div>
        <span class="mono rating-text">{rig.ratingText}</span>
        <span class="serif rating-label">{rig.ratingLabel}</span>
      </div>

      <div class="verdict serif">&ldquo;{rig.verdict}&rdquo;</div>

      <div class="mono label faint">Key specs</div>
      <dl class="mono specs">
        {rig.specs.map((sp) => (
          <div class="spec-row"><dt class="faint">{sp.k}</dt><dd>{sp.v}</dd></div>
        ))}
      </dl>

      <div class="mono label faint">Where to buy</div>
      <div class="buy-list">
        {rig.buy.map((b) => (
          <a href="#" class="buy-link">
            <span>{b.name}</span>
            <span class="mono price">{b.price} &#8599;</span>
          </a>
        ))}
      </div>

      <div class="pros-cons">
        <div class="col">
          <div class="mono col-title accent">Pros</div>
          <ul class="pros">
            {rig.pros.map((pro) => <li>{pro}</li>)}
          </ul>
        </div>
        <div class="col">
          <div class="mono col-title muted">Cons</div>
          <ul class="cons">
            {rig.cons.map((con) => <li>{con}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </div>
</aside>

<style>
  .rig-sidebar {
    flex: 1 1 296px;
    max-width: 340px;
    position: sticky;
    top: 24px;
  }
  .card {
    border: 1px solid var(--rule);
    background: var(--surface);
    border-radius: 3px;
    overflow: hidden;
  }
  .photo {
    height: 178px;
    border-bottom: 1px solid var(--rule);
    border-radius: 0;
    font-size: 11.5px;
  }
  .body {
    padding: 18px 18px 20px;
  }
  .label {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .accent {
    color: var(--accent);
  }
  .faint {
    color: var(--faint);
  }
  .muted {
    color: var(--muted);
  }
  .name {
    font-weight: 600;
    font-size: 22px;
    color: var(--ink);
    line-height: 1.2;
  }
  .rating {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 14px 0 16px;
  }
  .stars {
    display: flex;
    gap: 4px;
  }
  .star {
    width: 15px;
    height: 15px;
    border-radius: 2px;
    display: inline-block;
    box-sizing: border-box;
  }
  .star-full {
    background: var(--accent);
  }
  .star-half {
    background: linear-gradient(90deg, var(--accent) 50%, var(--surface2) 50%);
    border: 1px solid var(--rule);
  }
  .star-empty {
    background: var(--surface2);
    border: 1px solid var(--rule);
  }
  .rating-text {
    font-size: 13px;
    color: var(--ink);
  }
  .rating-label {
    font-style: italic;
    font-size: 14px;
    color: var(--muted);
  }
  .verdict {
    background: var(--accent-soft);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 11px 13px;
    margin-bottom: 18px;
    font-style: italic;
    font-size: 15.5px;
    line-height: 1.45;
    color: var(--ink);
  }
  .specs {
    margin: 0 0 18px;
    font-size: 12.5px;
    line-height: 1.5;
  }
  .spec-row {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 6px 0;
    border-bottom: 1px solid var(--rule);
  }
  .spec-row dd {
    margin: 0;
    color: var(--ink);
    text-align: right;
  }
  .buy-list {
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin-bottom: 18px;
  }
  .buy-link {
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 9px 11px;
    font-size: 14px;
    color: var(--ink);
  }
  .buy-link:hover {
    border-color: var(--accent);
  }
  .price {
    font-size: 12px;
    color: var(--accent);
  }
  .pros-cons {
    display: flex;
    gap: 14px;
  }
  .col {
    flex: 1;
  }
  .col-title {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .pros,
  .cons {
    margin: 0;
    padding: 0;
    list-style: none;
    font-size: 13.5px;
    line-height: 1.5;
  }
  .pros {
    color: var(--ink);
  }
  .cons {
    color: var(--muted);
  }
  .pros li,
  .cons li {
    margin-bottom: 6px;
    padding-left: 14px;
    position: relative;
  }
  .pros li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .cons li::before {
    content: '\2212';
    position: absolute;
    left: 0;
  }
</style>
