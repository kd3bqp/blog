---
interface Spec { k: string; v: string }
interface Buy { name: string; price: string }
interface Rig {
  name: string;
  photo?: string;
  photoLabel: string;
  ratingValue: number;
  ratingText: string;
  ratingLabel: string;
  verdict: string;
  specs: Spec[];
  buy: Buy[];
  pros: string[];
  cons: string[];
}

interface Props {
  rig: Rig;
}

const { rig } = Astro.props;

function starType(v: number, i: number): 'full' | 'half' | 'empty' {
  if (v >= i) return 'full';
  if (v >= i - 0.5) return 'half';
  return 'empty';
}
const stars = [1, 2, 3, 4, 5].map((i) => starType(rig.ratingValue, i));
---

<div class="rig-backdrop" id="rig-backdrop"></div>
<button class="rig-fab mono" id="rig-fab" aria-label="Show rig specs">
  📻 Overview
</button>
<aside class="rig-sidebar" id="rig-sidebar">
  <button class="rig-close mono" id="rig-close" aria-label="Close">&#x2715;</button>
  <div class="card">
    {rig.photo ? (
      <div class="photo photo-placeholder">
        {rig.photoLabel}
        <img
          src={rig.photo}
          alt={rig.photoLabel ?? rig.name}
          loading="lazy"
          onload="this.parentElement.classList.add('photo-loaded')"
        />
      </div>
    ) : (
      <div class="photo photo-placeholder">{rig.photoLabel}</div>
    )}
    <div class="body">
      <div class="mono label accent">The rig</div>
      <div class="serif name">{rig.name}</div>

      <div class="rating">
        <div class="stars">
          {stars.map((t) => <span class={`star star-${t}`}></span>)}
        </div>
        <span class="mono rating-text">{rig.ratingText}</span>
        <span class="serif rating-label">{rig.ratingLabel}</span>
      </div>

      <div class="verdict serif">&ldquo;{rig.verdict}&rdquo;</div>

      <div class="mono label faint">Key specs</div>
      <dl class="mono specs">
        {rig.specs.map((sp) => (
          <div class="spec-row"><dt class="faint">{sp.k}</dt><dd>{sp.v}</dd></div>
        ))}
      </dl>

      <div class="mono label faint">Where to buy</div>
      <div class="buy-list">
        {rig.buy.map((b) => (
          <a href="#" class="buy-link" data-buy-link={b.name}>
            <span>{b.name}</span>
            <span class="mono price">{b.price} &#8599;</span>
          </a>
        ))}
      </div>

      <div class="pros-cons">
        <div class="col">
          <div class="mono col-title accent">Pros</div>
          <ul class="pros">
            {rig.pros.map((pro) => <li>{pro}</li>)}
          </ul>
        </div>
        <div class="col">
          <div class="mono col-title muted">Cons</div>
          <ul class="cons">
            {rig.cons.map((con) => <li>{con}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </div>
</aside>

<script>
  const sidebar = document.getElementById('rig-sidebar')!;
  const fab = document.getElementById('rig-fab')!;
  const close = document.getElementById('rig-close')!;
  const backdrop = document.getElementById('rig-backdrop')!;

  function open() {
    sidebar.classList.add('drawer-open');
    backdrop.classList.add('backdrop-open');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    sidebar.classList.remove('drawer-open');
    backdrop.classList.remove('backdrop-open');
    document.body.style.overflow = '';
  }

  fab.addEventListener('click', open);
  close.addEventListener('click', closeDrawer);
  backdrop.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeDrawer(); });
</script>

<style>
  .rig-fab {
    display: none;
  }
  .rig-close {
    display: none;
  }
  .rig-backdrop {
    display: none;
  }

  .rig-sidebar {
    flex: 1 1 296px;
    max-width: 340px;
    position: sticky;
    top: 24px;
    align-self: start;
    max-height: calc(100vh - 48px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--rule) transparent;
  }
  .rig-sidebar::-webkit-scrollbar {
    width: 4px;
  }
  .rig-sidebar::-webkit-scrollbar-track {
    background: transparent;
  }
  .rig-sidebar::-webkit-scrollbar-thumb {
    background: var(--rule);
    border-radius: 2px;
  }

  @media (max-width: 767px) {
    .rig-fab {
      display: flex;
      align-items: center;
      gap: 8px;
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 90;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 999px;
      padding: 12px 20px;
      font-size: 13px;
      letter-spacing: 0.04em;
      cursor: pointer;
      box-shadow: 0 4px 16px rgba(0,0,0,0.18);
    }
    .rig-close {
      display: block;
      position: absolute;
      top: 12px;
      right: 14px;
      background: none;
      border: none;
      font-size: 16px;
      color: var(--muted);
      cursor: pointer;
      z-index: 1;
      padding: 4px 6px;
    }
    .rig-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      z-index: 95;
      opacity: 0;
      pointer-events: none;
    }
    @media (prefers-reduced-motion: no-preference) {
      .rig-backdrop { transition: opacity 0.25s ease; }
    }
    .rig-backdrop.backdrop-open {
      opacity: 1;
      pointer-events: auto;
    }
    .rig-sidebar {
      position: fixed;
      top: 0;
      right: -360px;
      width: 320px;
      max-width: 85vw;
      height: 100dvh;
      max-height: none;
      z-index: 100;
      border-left: 1px solid var(--rule);
      background: var(--bg);
    }
    @media (prefers-reduced-motion: no-preference) {
      .rig-sidebar { transition: right 0.3s ease; }
    }
    .rig-sidebar.drawer-open {
      right: 0;
    }
    .card {
      border: none;
      border-radius: 0;
      min-height: 100%;
    }
  }
  .card {
    border: 1px solid var(--rule);
    background: var(--surface);
    border-radius: 3px;
    overflow: hidden;
  }
  .photo {
    height: 178px;
    border-bottom: 1px solid var(--rule);
    border-radius: 0;
    font-size: 11.5px;
    position: relative;
  }
  .photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .photo-loaded img {
    opacity: 1;
  }
  .photo-loaded {
    background: none;
    border: none;
    color: transparent;
  }
  .body {
    padding: 18px 18px 20px;
  }
  .label {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .accent {
    color: var(--accent);
  }
  .faint {
    color: var(--faint);
  }
  .muted {
    color: var(--muted);
  }
  .name {
    font-weight: 600;
    font-size: 22px;
    color: var(--ink);
    line-height: 1.2;
  }
  .rating {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 14px 0 16px;
  }
  .stars {
    display: flex;
    gap: 4px;
  }
  .star {
    width: 15px;
    height: 15px;
    border-radius: 2px;
    display: inline-block;
    box-sizing: border-box;
  }
  .star-full {
    background: var(--accent);
  }
  .star-half {
    background: linear-gradient(90deg, var(--accent) 50%, var(--surface2) 50%);
    border: 1px solid var(--rule);
  }
  .star-empty {
    background: var(--surface2);
    border: 1px solid var(--rule);
  }
  .rating-text {
    font-size: 13px;
    color: var(--ink);
  }
  .rating-label {
    font-style: italic;
    font-size: 14px;
    color: var(--muted);
  }
  .verdict {
    background: var(--accent-soft);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 11px 13px;
    margin-bottom: 18px;
    font-style: italic;
    font-size: 15.5px;
    line-height: 1.45;
    color: var(--ink);
  }
  .specs {
    margin: 0 0 18px;
    font-size: 12.5px;
    line-height: 1.5;
  }
  .spec-row {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 6px 0;
    border-bottom: 1px solid var(--rule);
  }
  .spec-row dd {
    margin: 0;
    color: var(--ink);
    text-align: right;
  }
  .buy-list {
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin-bottom: 18px;
  }
  .buy-link {
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 9px 11px;
    font-size: 14px;
    color: var(--ink);
  }
  .buy-link:hover {
    border-color: var(--accent);
  }
  .price {
    font-size: 12px;
    color: var(--accent);
  }
  .pros-cons {
    display: flex;
    gap: 14px;
  }
  .col {
    flex: 1;
  }
  .col-title {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .pros,
  .cons {
    margin: 0;
    padding: 0;
    list-style: none;
    font-size: 13.5px;
    line-height: 1.5;
  }
  .pros {
    color: var(--ink);
  }
  .cons {
    color: var(--muted);
  }
  .pros li,
  .cons li {
    margin-bottom: 6px;
    padding-left: 14px;
    position: relative;
  }
  .pros li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .cons li::before {
    content: '\2212';
    position: absolute;
    left: 0;
  }
</style>
