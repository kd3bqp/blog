---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { cat, date, read, title, excerpt } = post.data;
const href = `/posts/${post.id}/`;
---

<article class="post-card" data-cat={cat}>
  <div class="meta mono">
    <span class="cat">{cat}</span>
    <span class="dot faint">&middot;</span>
    <span>{date}</span>
    <span class="dot faint">&middot;</span>
    <span>{read}</span>
  </div>
  <h2 class="serif title"><a href={href}>{title}</a></h2>
  <p class="excerpt">{excerpt}</p>
  <a href={href} class="mono read-more">Read the post &rarr;</a>
</article>

<style>
  .post-card {
    padding: 0 0 30px;
    margin-bottom: 30px;
    border-bottom: 1px solid var(--rule);
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 12px;
    font-size: 11.5px;
    letter-spacing: 0.05em;
    color: var(--muted);
  }
  .cat {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.09em;
  }
  .faint {
    color: var(--faint);
  }
  .title {
    margin: 0 0 12px;
    font-weight: 600;
    font-size: 27px;
    line-height: 1.2;
    color: var(--ink);
  }
  .title a {
    cursor: pointer;
  }
  .title a:hover {
    color: var(--accent);
  }
  .excerpt {
    margin: 0 0 14px;
    font-size: 16.5px;
    line-height: 1.65;
    color: var(--muted);
    max-width: 60ch;
  }
  .read-more {
    cursor: pointer;
    font-size: 12px;
    letter-spacing: 0.05em;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .read-more:hover {
    gap: 11px;
  }
</style>
