<div class="photo-modal" data-photo-modal hidden>
  <div class="backdrop" data-photo-close></div>
  <div class="frame">
    <img
      src="https://cdn.kd3bqp.radio/blogphotos/IMG_3437.jpeg"
      alt="Ethan — KD3BQP"
      referrerpolicy="no-referrer"
    />
    <button type="button" class="close-btn" data-photo-close aria-label="Close photo">&#215;</button>
  </div>
</div>

<style>
  .photo-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .photo-modal:not([hidden]) {
    display: flex;
  }
  .backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.82);
  }
  .frame {
    position: relative;
  }
  .frame img {
    display: block;
    max-width: min(700px, 90vw);
    max-height: 88vh;
    border-radius: 8px;
    object-fit: contain;
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.7);
  }
  .close-btn {
    position: absolute;
    top: -14px;
    right: -14px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(20, 20, 20, 0.8);
    color: #fff;
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .close-btn:hover {
    background: rgba(0, 0, 0, 1);
  }
</style>

<script>
  const modal = document.querySelector<HTMLElement>('[data-photo-modal]');
  if (modal) {
    document.querySelectorAll<HTMLElement>('[data-photo-trigger]').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        modal.hidden = false;
      });
    });
    modal.querySelectorAll<HTMLElement>('[data-photo-close]').forEach((el) => {
      el.addEventListener('click', () => {
        modal.hidden = true;
      });
    });
    modal.querySelector('.frame')?.addEventListener('click', (e) => e.stopPropagation());
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') modal.hidden = true;
    });
  }
</script>
