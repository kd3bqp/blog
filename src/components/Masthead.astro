---
interface Props {
  active?: 'home' | 'blog' | 'about' | 'contact';
  showActivity?: boolean;
}

const { active, showActivity = true } = Astro.props;
---

<header class="masthead">
  <div class="row">
    <a href="/" class="brand">
      <div class="mono name">KD3BQP</div>
      <div class="serif tagline">Ethan &middot; Amateur radio operator &mdash; York, Pennsylvania &middot; Grid FM19px</div>
    </a>
    <nav class="nav">
      <a href="/" class={`nav-link mono ${active === 'home' ? 'active' : ''}`}>Home</a>
      <a href="/blog" class={`nav-link mono ${active === 'blog' ? 'active' : ''}`}>Blog</a>
      <a href="/about" class={`nav-link mono ${active === 'about' ? 'active' : ''}`}>About</a>
      <a href="/contact" class={`nav-link mono ${active === 'contact' ? 'active' : ''}`}>Contact</a>
      <button type="button" class="theme-btn mono" data-theme-toggle>
        <span class="dot"></span><span data-theme-label>Paper</span>
      </button>
    </nav>
  </div>

  {
    showActivity && (
      <div class="activity mono">
        <span>
          <span class="faint">GRID</span> <span class="ink">FM19px</span>
        </span>
        <span>
          <span class="faint">CLUB</span> <span class="ink">YARS &middot; York PA</span>
        </span>
        <span>
          <span class="faint">MONITORING</span> <span class="ink">146.520 FM</span>
        </span>
        <span class="qrv">&bull; QRV</span>
      </div>
    )
  }

  <div class="dashed-rule"></div>
</header>

<style>
  .masthead {
    padding: 30px 0 0;
  }
  .row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 18px;
  }
  .brand {
    cursor: pointer;
    display: block;
  }
  .name {
    font-weight: 700;
    font-size: clamp(27px, 8vw, 34px);
    letter-spacing: 0.14em;
    color: var(--ink);
    line-height: 1;
  }
  .tagline {
    font-style: italic;
    font-size: 15px;
    color: var(--muted);
    margin-top: 8px;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }
  .nav-link {
    cursor: pointer;
    font-size: 12.5px;
    letter-spacing: 0.04em;
    padding: 7px 11px;
    border-radius: 2px;
    color: var(--muted);
  }
  .nav-link:hover {
    color: var(--accent);
  }
  .nav-link.active {
    color: var(--accent);
    background: var(--accent-soft);
  }
  .theme-btn {
    margin-left: 10px;
    cursor: pointer;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 7px 11px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .theme-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
    display: inline-block;
  }
  .activity {
    margin-top: 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 22px;
    font-size: 11.5px;
    letter-spacing: 0.04em;
    color: var(--muted);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 9px 0;
  }
  .faint {
    color: var(--faint);
  }
  .ink {
    color: var(--ink);
  }
  .qrv {
    color: var(--accent);
  }
  .dashed-rule {
    margin: 18px 0 0;
  }
</style>
