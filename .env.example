# Google Analytics
PUBLIC_GA_ID=

# Cloudflare Turnstile
PUBLIC_TURNSTILE_SITE_KEY=
PUBLIC_TURNSTILE_DISABLED=false

# Comments (Artalk) — set ARTALK_SERVER and flip COMMENTS_ENABLED to "true" once Artalk is deployed.
PUBLIC_COMMENTS_ENABLED=false
PUBLIC_ARTALK_SERVER=

# Contact form — N8N webhook URL that receives { name, email, callsign, phone, message, messageHtml }.
PUBLIC_N8N_WEBHOOK_URL=

# "From the shack" photo carousel on the home page — flip to "true" once real photos are ready.
PUBLIC_SHOW_CAROUSEL=false
